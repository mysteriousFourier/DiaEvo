DEEPSEEK_API_KEY=sk-your-real-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_MAX_TOKENS=4096
DEEPSEEK_TEMPERATURE=0.3
DEEPSEEK_REASONING_EFFORT=high
DEEPSEEK_THINKING=enabled
DEEPSEEK_TIMEOUT=0

GLM_VISION_API_KEY=your-real-glm-api-key
GLM_VISION_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM_VISION_MODEL=glm-4.6v-flash
GLM_VISION_MAX_TOKENS=4096
GLM_VISION_TEMPERATURE=0.2
GLM_VISION_TIMEOUT=0

DIAEVO_KG_VECTOR_BACKEND=tfidf
DIAEVO_KG_EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
DIAEVO_HF_ENDPOINT=https://hf-mirror.com

DIAEVO_QQ_ENABLED=false
DIAEVO_QQ_ALLOWED_USERS=123456789
DIAEVO_QQ_ONEBOT_WS_URL=ws://127.0.0.1:3001
DIAEVO_QQ_ONEBOT_HTTP_URL=http://127.0.0.1:3000
DIAEVO_QQ_ACCESS_TOKEN=
DIAEVO_QQ_APPROVAL_TTL_SECONDS=300
DIAEVO_QQ_MAX_MESSAGE_CHARS=1800
DIAEVO_QQ_NAPCAT_AUTOSTART=true
# If auto-discovery cannot find NapCat, DiaEvo can download the Windows one-key package into .tmp\napcat.
DIAEVO_QQ_NAPCAT_AUTO_INSTALL=true
DIAEVO_QQ_NAPCAT_DOWNLOAD_URL=https://github.com/NapNeko/NapCatQQ/releases/latest/download/NapCat.Shell.Windows.OneKey.zip
# Optional override; DiaEvo auto-discovers NapCat from PATH, npm global bin, common install dirs, and workspace .tmp\napcat.
DIAEVO_QQ_NAPCAT_COMMAND=
DIAEVO_QQ_NAPCAT_STARTUP_WAIT_SECONDS=25
